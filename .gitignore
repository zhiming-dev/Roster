# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

# Node / Python
node_modules/
__pycache__/
*.pyc
.venv/
venv/
runtime/.venv/
dist/
build/
# Built SPA: regenerated by `npm run build` in frontend/ (and by the Docker image's
# frontend stage); FastAPI serves it at /.
runtime/static/app/
*.egg-info/
*.log

# Test / coverage / notebook artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.ipynb_checkpoints/

# Playwright CLI working directories (regeneratable)
.playwright-cli/
qa-agent/e2e-test/test-results/
qa-agent/e2e-test/failure-screenshots/

# Local runs (each run is principal- and machine-specific)
runs/
!runs/.gitkeep

# Local per-developer memory bank (keep only the template README tracked)
.memory-bank/activeContext.md
.memory-bank/learnings.md
.memory-bank/userDirectives.md
!.memory-bank/README.md

# SQLite persistence (chat history DB + run artifacts on the Docker volume)
runtime/data/
*.db
*.sqlite
*.sqlite3

# Research outputs (reproducible from the harness)
research/results/
research/.cache/

# Secrets — never commit
.env
.env.*
*.pem
*.key
# The live runtime config holds real endpoints/keys — never commit it.
# The committed template is runtime/agents.config.example.yaml (kept below).
*agents.config.yaml
!*agents.config.example.yaml

# Runtime/editor local state
runtime/.mypy_cache/
runtime/.ruff_cache/